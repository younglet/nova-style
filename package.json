{
  "name": "nova-style",
  "version": "2.0.0",
  "private": false,
  "type": "module",
  "description": "IoT 原子 CSS 工具类。120 个 class · 12KB min · 内置暗色模式。",
  "scripts": {
    "build": "csso src/nova-style.css -o src/nova-style.min.css",
    "sync": "node scripts/sync-public.js",
    "predocs:dev": "npm run build && npm run sync",
    "predocs:build": "npm run build && npm run sync",
    "docs:dev": "vitepress dev docs --port 5174 --host 0.0.0.0",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs"
  },
  "keywords": [
    "css",
    "utility-first",
    "iot",
    "dashboard",
    "tailwind-alternative"
  ],
  "devDependencies": {
    "csso-cli": "^4.0.2",
    "vitepress": "^1.5.0",
    "vue": "^3.5.0"
  },
  "license": "MIT",
  "author": "stemstar <https://github.com/younglet>",
  "repository": {
    "type": "git",
    "url": "https://github.com/younglet/nova-style.git"
  },
  "homepage": "https://younglet.github.io/nova-style/",
  "bugs": {
    "url": "https://github.com/younglet/nova-style/issues"
  }
}
